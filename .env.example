# France Travail API Credentials
# Get yours at: https://francetravail.io
FRANCE_TRAVAIL_CLIENT_ID=your_client_id_here
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret_here

# La bonne alternance API Key
# Request at: support_api@apprentissage.beta.gouv.fr
LBA_API_KEY=your_lba_api_key_here

# Anthropic API Key (for cover letter generation)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Auth credentials
ADMIN_USERNAME=mathias
ADMIN_PASSWORD=your_admin_password_here
VIEWER_USERNAME=invite
VIEWER_PASSWORD=your_viewer_password_here

# Flask Configuration
FLASK_SECRET_KEY=your_random_secret_key_here_change_this
FLASK_DEBUG=true
FLASK_ENV=development

# Database
DATABASE_PATH=data/jobhunter.db

# Scheduler Settings
SCRAPER_SCHEDULE_HOUR=8
SCRAPER_SCHEDULE_MINUTE=0

# Scraping Configuration
SCRAPING_DELAY_MIN=2
SCRAPING_DELAY_MAX=5
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Selenium Configuration (for JS-rendered sites)
SELENIUM_HEADLESS=true
SELENIUM_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/jobhunter.log

# Deployment
# Domain name used in nginx server_name directive (optional, can leave blank)
DOMAIN_NAME=yourdomain.com

# Email / SMTP (Flask-Mail) — used to send password reset links
MAIL_SERVER=ssl0.ovh.net
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=noreply@myjobhunter.fr
MAIL_PASSWORD=your_smtp_password_here
MAIL_DEFAULT_SENDER=noreply@myjobhunter.fr
